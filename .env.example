# card-trade-social local configuration template
# Copy to .env for local development. Do not commit real secrets.

# Auth / API-key issuance
HYDRA_API_KEY_SECRET=replace-with-32-plus-random-characters
HYDRA_AUTH_ISSUER=card-trade-social

# Required service dependencies
TCGPLAYER_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_PROXY_PRINT_CREDIT=
STRIPE_PRICE_AVATAR_SKIN=
STRIPE_PRICE_GUILD_BANNER=
DATABASE_URL=
REDIS_URL=

# Optional Merchant of Record checkout
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_VARIANT_PRO_MONTHLY=
LEMON_SQUEEZY_VARIANT_PRO_YEARLY=

# Optional feature-gated integrations
OPENAI_API_KEY=
STABILITY_API_KEY=
EBAY_APP_ID=
COINBASE_COMMERCE_KEY=
